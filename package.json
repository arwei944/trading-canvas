{
  "name": "trading-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "基于 BlockCanvas 的加密货币交易日志前端",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "build:packages": "pnpm --filter '@trading-canvas/*' build",
    "test": "pnpm --filter web test",
    "lint": "pnpm --filter web lint",
    "clean": "rm -rf node_modules packages/*/dist apps/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.4.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
